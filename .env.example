# ─── Supabase ───────────────────────────────────────────────
# Copia estos valores desde: supabase.com → tu proyecto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX

# ─── App ────────────────────────────────────────────────────
# Pon aquí la IP local de tu QNAP con el puerto 8090
# Ejemplo: http://192.168.1.100:8090
NEXT_PUBLIC_APP_URL=http://192.168.1.100:8090

# ─── Seguridad cron ─────────────────────────────────────────
# Cualquier texto largo y aleatorio, solo para uso interno
CRON_SECRET=cambia-esto-por-algo-largo-y-aleatorio
